# PostgreSQL connection used by the API. Never place real credentials in source control.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=hospitality
DB_PASSWORD=replace-with-a-local-secret
DB_NAME=hospitality
# Use true for Neon and every remote database. false is accepted only for loopback development databases.
DB_SSL=false

# A cryptographically random secret of at least 32 characters for signing access tokens.
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters

# Comma-separated browser origins allowed to send credentialed requests.
CORS_ORIGINS=http://localhost:3000

# Set true only when local development is served over HTTPS; production forces secure cookies.
COOKIE_SECURE=false

# Typed feature flags accept only true or false. Malformed configured values fail closed.
# Existing concept capabilities default on; set them explicitly in deployed environments.
FEATURE_CONCEPT_PREVIEW=true
FEATURE_PUBLIC_WEBSITE=true
FEATURE_ONLINE_BOOKING=true
FEATURE_GUEST_ACCOUNTS=true
FEATURE_GUEST_BOOKING_HISTORY=true
FEATURE_WHATSAPP_CONTACT=true
FEATURE_STAFF_DASHBOARD=true
FEATURE_BOOKING_MANAGEMENT=true
FEATURE_AVAILABILITY_MANAGEMENT=true
FEATURE_CONTENT_MANAGEMENT=true

# Future capabilities default off and should remain disabled for Milestone 4A.
FEATURE_PAYMENTS=false
FEATURE_MOBILE_MONEY=false
FEATURE_MULTI_BUSINESS=false
FEATURE_BUSINESS_ONBOARDING=false
FEATURE_BUSINESS_SWITCHING=false
FEATURE_RESTAURANT_MODULE=false
FEATURE_RECREATION_MODULE=false
FEATURE_EVENT_VENUE_MODULE=false
FEATURE_REVIEWS=false
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_CUSTOM_DOMAINS=false
FEATURE_STAFF_INVITATIONS=false
